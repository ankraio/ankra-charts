# Patterns to ignore when building Helm packages.
.DS_Store
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
*.swp
*.bak
*.tmp
*.orig
*~
.project
.idea/
*.tmproj
.vscode/

# Vendored upstream YAML kept for diffing; not part of the rendered chart.
/vendor/

# CI/dev helpers. Anchored with a leading slash so they only match the chart
# root (otherwise `templates/tests/` — the helm-test hook pods — would be
# excluded from the rendered chart too).
/tests/
/values-examples/
/CHANGELOG.md
